import SwiftUI

struct NavigationList: View {
    let colors : [Color] = [.red, .green, .blue]
    var body: some View {
        NavigationStack{
            List(colors, id: \.self){
                color in NavigationLink (color.description){
                    color
                        .ignoresSafeArea()
                        .navigationTitle(color.description)
                        
                }
            }
            .navigationTitle("Colors")
        }
        
        
        
    }
}

