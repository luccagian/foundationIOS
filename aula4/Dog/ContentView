import SwiftUI

struct ContentView: View {
    @State private var dog: Dog?
    var body: some View {
        VStack {
            if let dog {
                AsyncImage(url: URL(string: dog.message))
            }
        }
        .task {
            try? await dog = DogAPI.fetchUser()
        }
    }
}

